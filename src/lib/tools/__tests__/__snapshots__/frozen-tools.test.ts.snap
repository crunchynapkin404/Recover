          "description": "Custom display color (hex string).",
          "type": "string",
        },
        "date": {
          "description": "Updated start date, YYYY-MM-DD.",
          "type": "string",
        },
        "description": {
          "description": "Event description. For WORKOUT events, use intervals.icu structured workout syntax.",
          "type": "string",
        },
        "distanceMeters": {
          "description": "Planned distance in meters.",
          "type": "number",
        },
        "durationSeconds": {
          "description": "Planned duration in seconds.",
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": "integer",
        },
        "endDate": {
          "description": "End date, YYYY-MM-DD. Use for ranged categories (INJURED, SICK, HOLIDAY, SEASON_START).",
          "type": "string",
        },
        "eventId": {
          "description": "The intervals.icu event ID to update.",
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": "integer",
        },
        "name": {
          "description": "Updated event name.",
          "type": "string",
        },
        "notOnFitnessChart": {
          "description": "Hide event entirely from the fitness chart.",
          "type": "boolean",
        },
        "showAsNote": {
          "description": "Show event as a note marker on the fitness chart.",
          "type": "boolean",
        },
        "showOnCtlLine": {
          "description": "Render event on the CTL line.",
          "type": "boolean",
        },
        "trainingAvailability": {
          "enum": [
            "NORMAL",
            "LIMITED",
            "UNAVAILABLE",
          ],
          "type": "string",
        },
        "trainingLoad": {
          "description": "Planned training load.",
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": "integer",
        },
        "type": {
          "description": "Activity discipline (not the category): Ride, Run, Swim, Walk, Hike, VirtualRide, VirtualRun, Other.",
          "type": "string",
        },
      },
      "required": [
        "eventId",
      ],
      "type": "object",
    },
    "scope": "write:icu",
  },
  {
    "name": "icu_update_sport_settings",
    "schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "fthr": {
          "description": "Functional/Lactate Threshold Heart Rate in bpm.",
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": "integer",
        },
        "ftp": {
          "description": "Functional Threshold Power in watts (cycling).",
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": "integer",
        },
        "hrZones": {
          "description": "Heart-rate zone boundaries.",
          "items": {
            "maximum": 9007199254740991,
            "minimum": -9007199254740991,
            "type": "integer",
          },
          "type": "array",
        },
        "maxHr": {
          "description": "Maximum heart rate in bpm.",
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": "integer",
        },
        "paceZones": {
          "description": "Pace zone boundaries.",
          "items": {
            "type": "number",
          },
          "type": "array",
        },
        "powerZones": {
          "description": "Power zone boundaries.",
          "items": {
            "maximum": 9007199254740991,
            "minimum": -9007199254740991,
            "type": "integer",
          },
          "type": "array",
        },
        "recalcHrZones": {
          "default": false,
          "description": "Recalculate HR zones from the new threshold values.",
          "type": "boolean",
        },
        "sportId": {
          "description": "ID of the sport-settings profile to update.",
          "type": "string",
        },
        "thresholdPace": {
          "description": "Threshold pace/speed for this sport, in the unit already configured for the profile (see paceUnits from icu_get_sport_settings).",
          "type": "number",
        },
        "wPrime": {
          "description": "W' (anaerobic work capacity) in joules.",
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": "integer",
        },
      },
      "required": [
        "sportId",
        "recalcHrZones",
      ],
      "type": "object",
    },
    "scope": "write:icu",
  },
  {
    "name": "icu_update_wellness",
    "schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
