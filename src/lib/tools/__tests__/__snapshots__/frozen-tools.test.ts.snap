  {
    "name": "render_chart",
    "schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "description": "Vertical markers (e.g., race day, today).",
          "items": {
            "additionalProperties": false,
            "properties": {
              "color": {
                "type": "string",
              },
              "label": {
                "type": "string",
              },
              "x": {
                "anyOf": [
                  {
                    "type": "string",
                  },
                  {
                    "type": "number",
                  },
                ],
              },
            },
            "required": [
              "x",
              "label",
            ],
            "type": "object",
          },
          "type": "array",
        },
        "series": {
          "description": "Data series to plot.",
          "items": {
            "additionalProperties": false,
            "properties": {
              "color": {
                "description": "Tailwind color name or hex. Defaults to theme palette.",
                "type": "string",
              },
              "data": {
                "items": {
                  "additionalProperties": false,
                  "properties": {
                    "x": {
                      "anyOf": [
                        {
                          "type": "string",
                        },
                        {
                          "type": "number",
                        },
                      ],
                    },
                    "y": {
                      "type": "number",
                    },
                  },
                  "required": [
                    "x",
                    "y",
                  ],
                  "type": "object",
                },
                "minItems": 1,
                "type": "array",
              },
              "label": {
                "type": "string",
              },
              "style": {
                "default": "solid",
                "enum": [
                  "solid",
                  "dashed",
                  "area",
                ],
                "type": "string",
              },
            },
            "required": [
              "label",
              "data",
              "style",
            ],
            "type": "object",
          },
          "minItems": 1,
          "type": "array",
        },
        "title": {
          "description": "Short chart title shown above the visualization.",
          "type": "string",
        },
        "type": {
          "description": "Chart type: line (time series), bar (categorical), area (filled), table (rows).",
          "enum": [
            "line",
            "bar",
            "area",
            "table",
          ],
          "type": "string",
        },
        "xLabel": {
          "description": "X-axis label.",
          "type": "string",
        },
        "yLabel": {
          "description": "Y-axis label.",
          "type": "string",
        },
      },
      "required": [
        "type",
        "title",
        "series",
      ],
      "type": "object",
    },
    "scope": "read",
  },
  {
    "name": "set_week_availability",
    "schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "availableMins": {
          "description": "Minutes available per day, Monday first",
          "items": {
            "maximum": 720,
            "minimum": 0,
