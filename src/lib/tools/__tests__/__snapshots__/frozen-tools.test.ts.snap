      "properties": {
        "action": {
          "enum": [
            "move",
            "swap",
            "skip",
          ],
          "type": "string",
        },
        "fromDate": {
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "type": "string",
        },
        "toDate": {
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "type": "string",
        },
      },
      "required": [
        "action",
        "fromDate",
      ],
      "type": "object",
    },
    "scope": "read",
  },
  {
    "name": "update_training_plan",
    "schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "action": {
          "description": "Week-level: adjusts the week's target load. Day-level (move_workout/swap_workout): rearranges the current week's days.",
          "enum": [
            "reduce_load",
            "increase_load",
            "skip_week",
            "move_workout",
            "swap_workout",
          ],
          "type": "string",
        },
        "fromDate": {
          "description": "YYYY-MM-DD — source day (day-level actions).",
          "type": "string",
        },
        "reason": {
          "description": "Why the adjustment is being made.",
          "type": "string",
        },
        "toDate": {
          "description": "YYYY-MM-DD — target day (day-level actions).",
          "type": "string",
        },
        "weekNumber": {
          "description": "Week to adjust (required for week-level actions).",
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": "integer",
        },
      },
      "required": [
        "action",
        "reason",
      ],
      "type": "object",
    },
    "scope": "write:plan",
  },
  {
    "name": "upsert_race",
    "schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "date": {
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "type": "string",
        },
        "goalNote": {
          "type": "string",
        },
        "id": {
          "description": "Set to update an existing race.",
          "format": "uuid",
          "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
          "type": "string",
        },
        "name": {
          "minLength": 1,
          "type": "string",
        },
        "priority": {
          "description": "A = full taper target; B = short pre-race ease-off; C = train through.",
          "enum": [
            "A",
            "B",
            "C",
          ],
          "type": "string",
        },
        "raceType": {
          "description": "Free text, e.g. "marathon", "70.3", "gran fondo", "10k".",
          "type": "string",
        },
        "sport": {
          "type": "string",
        },
        "status": {
          "enum": [
            "upcoming",
            "completed",
            "skipped",
          ],
          "type": "string",
        },
      },
