          "type": "integer",
        },
        "carbohydrates": {
          "description": "Carbohydrates consumed (grams).",
          "type": "number",
        },
        "comments": {
          "description": "Comments or notes.",
          "type": "string",
        },
        "date": {
          "description": "Date in YYYY-MM-DD format.",
          "type": "string",
        },
        "diastolic": {
          "description": "Diastolic blood pressure in mmHg.",
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": "integer",
        },
        "fatTotal": {
          "description": "Total fat consumed (grams).",
          "type": "number",
        },
        "fatigue": {
          "description": "Fatigue level, 1-5 (1=very low, 5=very high).",
