          "minimum": 1,
          "type": "integer",
        },
        "hrv": {
          "description": "HRV (rMSSD) value.",
          "type": "number",
        },
        "hydrationLiters": {
          "description": "Hydration volume (liters).",
          "type": "number",
        },
        "injury": {
          "description": "Injury severity, 1-5 (1=none, 5=severe).",
          "maximum": 5,
          "minimum": 1,
          "type": "integer",
        },
        "lactate": {
          "description": "Blood lactate in mmol/L — lab result.",
          "type": "number",
        },
        "locked": {
          "description": "Lock record to prevent device sync from overwriting manual entries.",
          "type": "boolean",
        },
        "menstrualPhase": {
          "description": "Menstrual phase, e.g. FOLLICULAR, OVULATING, LUTEAL, MENSTRUAL.",
          "type": "string",
        },
        "mood": {
          "description": "Mood level, 1-5 (1=very poor, 5=very good).",
          "maximum": 5,
          "minimum": 1,
          "type": "integer",
        },
        "motivation": {
          "description": "Motivation level, 1-5 (1=very low, 5=very high).",
          "maximum": 5,
          "minimum": 1,
          "type": "integer",
        },
        "protein": {
          "description": "Protein consumed (grams).",
          "type": "number",
        },
        "readiness": {
          "description": "Readiness score (0-100).",
          "type": "number",
        },
        "respiration": {
          "description": "Respiration rate in breaths per minute.",
          "type": "number",
        },
        "restingHr": {
          "description": "Resting heart rate in bpm.",
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": "integer",
        },
        "sleepQuality": {
          "description": "Sleep quality, 1-5 (1=Great, 5=Poor — inverted scale).",
          "maximum": 5,
          "minimum": 1,
          "type": "integer",
        },
        "sleepSecs": {
          "description": "Sleep duration in seconds.",
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": "integer",
        },
        "soreness": {
          "description": "Soreness level, 1-5 (1=very low, 5=very high).",
          "maximum": 5,
          "minimum": 1,
          "type": "integer",
        },
        "spo2": {
          "description": "Blood oxygen saturation percentage (SpO2).",
          "type": "number",
        },
        "stress": {
          "description": "Stress level, 1-5 (1=very low, 5=very high).",
          "maximum": 5,
          "minimum": 1,
          "type": "integer",
        },
        "systolic": {
          "description": "Systolic blood pressure in mmHg.",
          "maximum": 9007199254740991,
          "minimum": -9007199254740991,
          "type": "integer",
        },
        "vo2max": {
          "description": "VO2max (ml/kg/min) — lab result or device estimate.",
          "type": "number",
