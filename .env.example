# ── Required ─────────────────────────────────────────────────────────────────
# 64 hex chars (32 bytes) — encrypts connector/LLM keys at rest.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Session signing secret. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL of the app (change to your domain when using a tunnel/proxy).
BETTER_AUTH_URL=http://localhost:3000

# ── First boot ────────────────────────────────────────────────────────────────
# Seeds the owner account when the users table is empty (min 8 char password).
OWNER_EMAIL=you@example.com
OWNER_PASSWORD=

# ── Optional ──────────────────────────────────────────────────────────────────
# Postgres password used by docker-compose (default: recover).
#POSTGRES_PASSWORD=recover

# Host port for the app (default: 3000).
#APP_PORT=3000

# Extra trusted origins for auth, comma-separated (LAN IP, tunnel hostname).
# BETTER_AUTH_URL's origin is always trusted.
#TRUSTED_ORIGINS=

# Secret for the /api/cron fallback tick (serverless deploys only).
#CRON_SECRET=

# Strava OAuth app credentials (Settings → connect Strava).
#STRAVA_CLIENT_ID=
#STRAVA_CLIENT_SECRET=

# Cloudflare tunnel token (docker compose --profile tunnel up -d).
#CLOUDFLARED_TOKEN=

# Google Calendar OAuth credentials (Settings → connect Google Calendar).
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=

# Nightly backups: how many pg_dump files to keep (default 14).
#BACKUP_KEEP=14
